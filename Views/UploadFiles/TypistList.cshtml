@model IEnumerable<ExcelTranscript.Models.UploadedFile>
@using ExcelTranscript.Models;
@{
    ViewBag.Title = "TypistList";
    db_ExcelTransEntities db = new db_ExcelTransEntities();
    var obj = db.AspNetUsers;
}

<section class="content">

    <!-- *========== Main Heading ========== -->
    @*<div class="pt-3 pb-2">
            <div class="container-fluid">
                <h2 class="main-heading">Clinic List</h2>
            </div>
        </div>*@

    <!-- *========== Breadcrumbs ========== -->
    <div>
        <div class="container-fluid">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-white px-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("TypistList", "UploadFiles")">Home</a></li>
                    <li class="breadcrumb-item active">Typist List</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- *========== Data Table ========== -->
    <div class="py-3">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">
                    <table id="example" class="table table-striped table-bordered" style="width:100%">
                        <thead>
                            <tr>
                                <th>Audio File</th>
                                <th>Typist</th>
                            </tr>
                        </thead>
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @Html.DisplayFor(modelItem => item.FileName)
                                </td>
                                <td>
                                    @(obj.Where(sa=> sa.UserId == item.TypistAssignID).FirstOrDefault().UserName)
                                </td>

                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>

</section>

@section scripts{
    <script type="text/javascript">

        $("#example").DataTable();
    </script>
}
