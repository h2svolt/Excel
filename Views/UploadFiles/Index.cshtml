@model IEnumerable<ExcelTranscript.Models.UploadedFile>

@{
    ViewBag.Title = "Dictations List";

    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .disablefocus:focus {
        box-shadow: none !important;
        border-color: #b5b5b5;
    }

    .disablefocus {
        border-color: #b5b5b5;
        font-size: 14px !important;
        height: 31px !important;
    }
</style>

<section class="content">

    <div class="container-fluid">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb bg-white px-0 mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "UploadFiles")">Home</a></li>
                <li class="breadcrumb-item active">Dictations</li>
                <li class="breadcrumb-item active">@ViewBag.Title</li>
            </ol>
        </nav>
    </div>
    <!-- *========== Data Table ========== -->
    <div class="py-3">
        <div class="container-fluid">
            <div class="row">
                <a id="test" hidden download>  </a>
                <div>
                    <input type="button" class="btn btn-primary" value="Download" hidden id="submitBtn" />
                </div>
                <div class="col-md-12">

                    <form action="" method="" class="py-2 px-3 box-shadow box-rounded">
                        <div class="row">
                            <div class="col-md-12">
                                <h5 class="form-title p-0 mb-1"><i class="fa fa-filter" aria-hidden="true"></i> Filter</h5>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group m-0">
                                    <label class="m-0" for="Clinic">Clinic</label>
                                    @if (User.IsInRole("Provider"))
                                    {
                                        @Html.DropDownList("ClinicID", new SelectList(ViewBag.ClinicID, "value", "text"), htmlAttributes: new { @class = "select2 form-control", @Disabled = "Disabled" })
                                    }
                                    else
                                    {
                                        @Html.DropDownList("ClinicID", new SelectList(ViewBag.ClinicID, "value", "text"), "Select Clinic", htmlAttributes: new { @class = "select2 form-control" })
                                    }
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group m-0">
                                    <label class="m-0" for="Provider">Provider</label>
                                    @if (User.IsInRole("Provider"))
                                    {
                                        @Html.DropDownList("DictatorID", new SelectList(ViewBag.DictatorID, "value", "text"), htmlAttributes: new { @class = "select2 form-control", @Disabled = "Disabled" })
                                    }
                                    else
                                    {
                                        @Html.DropDownList("DictatorID", new SelectList(ViewBag.DictatorID, "value", "text"), "Select Provider", htmlAttributes: new { @class = "select2 form-control" })
                                    }

                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group m-0">
                                    <label class="m-0" for="Typist">Typist</label>
                                    @if (User.IsInRole("Typist"))
                                    {
                                        @Html.DropDownList("TypistAssignID", new SelectList(ViewBag.GetTypist, "value", "text"), htmlAttributes: new { @class = "select2 form-control", @Disabled = "Disabled" })
                                    }
                                    else
                                    {
                                        @Html.DropDownList("TypistAssignID", new SelectList(ViewBag.GetTypist, "value", "text"), "Select Typist", htmlAttributes: new { @class = "select2 form-control" })
                                    }
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-group m-0">
                                    <label class="m-0" for="Status">Dictation Status</label>
                                    @Html.DropDownList("StatusId", new SelectList(ViewBag.StatusId, "value", "text"), "Select Status", htmlAttributes: new { @class = "select2 form-control" })
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group m-0">
                                    <label class="m-0" for="from">From</label>
                                    <input id="fromDate" type="text" class="form-control disablefocus" name="from">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group m-0">
                                    <label class="m-0" for="to">To</label>
                                    <input id="toDate" type="text" class="form-control disablefocus" name="to">
                                </div>
                            </div>
                            <div class="col-md-10">
                            </div>
                            <div class="col-md-2">
                                <label class="text-white m-0">asdf</label>

                                <button type="button" class="btn btn-block btn-primary" id="btnSearch">
                                    <i class="fa fa-search"></i>&nbsp;Search
                                </button>

                            </div>
                        </div>
                    </form>

                    <div id="SearchResult">

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section scripts{
    <script src="~/Scripts/General.js"></script>
    <script>
        let uploadsDataTable;

        $(document).ready(function () {

            $("#DictatorID").select2();
            $("#ClinicID").select2();
            $("#StatusId").select2();
            $("#TypistAssignID").select2();

            var date = new Date();
            date.setDate(date.getDate() - 1);

            $("#fromDate").datepicker({
                dateFormat: 'mm/dd/yy'
            });
            $("#toDate").datepicker({
                dateFormat: 'mm/dd/yy'
            });
            $("#fromDate").datepicker('setDate', date);
            $("#toDate").datepicker('setDate', new Date());
            $("#btnSearch").trigger("click");
        });

        $('#example tbody').on('click', 'tr', function () {
            $(this).toggleClass('selected');
        });

        $(document).on('change', '#select_all', function () {
            if ($(this).is(":checked")) {
                //$("input[type='checkbox']").prop('checked', true);
                $("#example").DataTable().rows().select();
                $('#example > tbody').find('tr').each(function (i) {
                    var $row = $(this).find('td');
                    var id = $row.eq(0).find(".fileID").val();
                    if (id != undefined || id != 0) {
                        arr += id + ',';
                    }
                });
            } else {
                $("#example").DataTable().rows().deselect();
                //$("input[type='checkbox']").prop('checked', false);
                arr = "";
            }
        });


        //".checkbox" change
        $('.checkbox').change(function () {
            //uncheck "select all", if one of the listed checkbox item is unchecked
            if ($(this).prop("checked") == false) { //if this item is unchecked
                $("#select_all").prop('checked', false); //change "select all" checked status to false
            }
            //check "select all" if all checkbox items are checked
            if ($('.checkbox:checked').length == $('.checkbox').length) {
                $("#select_all").prop('checked', true);
            }
        });

         $("#btnSearch").on("click", function () {
            $('.Loader').show();
            var DictatorID = $('#DictatorID').val();
            if (DictatorID == '') {
                $("#DictatorID option").each(function (){
                    DictatorID += $(this).val() +",";
                });
            }

            var ClinicID = $('#ClinicID').val();
            if (ClinicID == '') {
                $("#ClinicID option").each(function (){
                    ClinicID += $(this).val() +",";
                });
            }

            var fromDate = $('#fromDate').val();
            var toDate = $('#toDate').val();
            var StatusId = $('#StatusId').val();
            var html = '<img src="@ViewBag.Picture" class="brand-logo" align = "left" margin="10px"><h1  align="center">@ViewBag.CompanyName</h1><h5 align="center">@ViewBag.CompanyAddress </h5><h5 align="center">Contact: @ViewBag.CompanyCell</h5><hr /><h4 align="center"> @ViewBag.Title </h4>';


            if (fromDate != "" && toDate != "") {
                html += "<h4>From:    " + fromDate + "            TO:    " + toDate + " </h4>";
            }
             if (fromDate != "" && toDate != "" && (new Date($("#fromDate").val())) != "Invalid Date" && (new Date($("#toDate").val()) != "Invalid Date")) {
                $.ajax({
                    url: "@Url.Action("Index", "UploadFiles")",
                    data: {
                        btn: true,
                        DictatorID: DictatorID,
                        ClinicID:   ClinicID,
                        TypistID: $('#TypistAssignID').val(),
                        StatusId: $('#StatusId').val(),
                        fromDate: $('#fromDate').val(),
                        toDate: $('#toDate').val(),
                    },
                    success: function (data) {
                        $("#SearchResult").html(data);
                        uploadsDataTable = $('#example').dataTable({
                            columnDefs: [{
                                orderable: false,
                                className: 'select-checkbox',
                                targets: 0
                            }],
                            select: {
                                style: 'multi',
                                selector: 'td:first-child'
                            },
                            ordering: false,
                            stateSave: true,
                            dom: '<"top" lB> frtip',
                            lengthMenu: [
                                [10, 25, 50, 100, -1],
                                [10, 25, 50, 100, 'All'],
                            ],
                            buttons: [
                                {
                                    text: '<i class="fa fa-refresh"></i> Refresh',
                                    className: 'btn-refresh',
                                    action: function (e, dt, node, config) {
                                        $('#btnSearch').click();
                                    }
                                },
                                {
                                    extend: 'print',
                                    messageTop: function () {
                                        return '<h3 align="center">@ViewBag.Title</h3>';
                                        //return '<h3 align="center" style="margin-top:208px; margin-bottom:76px;">Products List</h3>';
                                    },
                                    title: '',
                                    messageBottom: 'Powered by H2S Volt',
                                    exportOptions: {
                                        columns: [1, 2, 3, 4, 5, 6]
                                    }
                                },
                                {
                                    extend: 'excel',
                                    messageTop: '@ViewBag.Title',
                                    messageBottom: 'Powered by H2S Volt',
                                    //exportOptions: {
                                    //    //columns: [0, 1, 2, 3]
                                    //}
                                },
                                  {
                                    text: 'Download Selected',
                                    action: function (e, dt, node, config) {
                                        var selectedItems = $('#example').DataTable().rows({ selected: true });
                                        DownLoadSelectedItems(selectedItems);
                                    }
                                },
                                {
                                    text: 'Delete Selected',
                                    action: function (e, dt, node, config) {
                                        var selectedItems = $('#example').DataTable().rows({ selected: true });
                                        BulkDelete(selectedItems);
                                    }
                                }
                            ]
                        });
                        $('.Loader').hide();
                    },
                    error: function (xhr, status) {
                        $('.Loader').hide();
                    }
                });
            }
            else {
                $('.Loader').hide();
                swal({
                    title: "Invalid Date",
                    text: "Please select correct date range!",
                    icon: "warning",
                    buttons: false,
                    timer: 2500
                });
            }
        });


        $('#submitBtn1').click(function () {
            console.log("test");
            //var STRMS = [];
            var STRMS = Array();

            var chkall = $("#select_all").is(':checked');
            console.log(chkall);
            if (chkall == true) {
                var url = '@Url.Action("DownloadFiles", "UploadFiles")?STRMSelected';
                window.open(url, "_blank")
                @*$.ajax({
                    type: "Get",
                    url: '@Url.Action("DownloadFiles", "UploadFiles")',
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify({ 'STRMSelected': null }),
                    success:
                        function (data) {
                                alert("Downloaded Successfully")

                            $("#test").attr("href", data[i]);
                            $("#test").click();

                            //else ("Download failed")
                        }

                });*@
            }
            else {

                $('#example > tbody').find('tr').each(function (i) {

                    var $row = $(this).find('td');

                    if ($row.eq(0).find("input")[0].checked == true) {

                        STRMS.push($row.eq(0).find("input")[0].id);
                        console.log($row.eq(0).find("input")[0].id);
                    }
                });
                //$('#example tbody tr').each(function (i, n) {
                //    var $row = $(n);

                //    if ($row.find('input[id = "selectedid"]').is(':checked')) {

                //        STRMS.push($row.find('input[id="selectedid"]').val());
                //    }
                //});
                var param = '';
                for (var i = 0; i < STRMS.length; i++) {
                    param += `STRMSelected[${i}]=` + STRMS[i] + `&`;
                }
                console.log(STRMS);

                param = param.substring(0, param.length - 1);

                var url = '@Url.Action("DownloadFiles", "UploadFiles")?' + param;

                window.open(url, "_blank")

                console.log(param);


                @*$.ajax({
                    type: "Get",
                    url: '@Url.Action("DownloadFiles", "UploadFiles")?'+param,
                    contentType: "application/json; charset=utf-8",
                  //  data: JSON.stringify({ 'STRMSelected': STRMS }),
                    success:
                        function (data) {
                            if (data == true)
                                alert("Downloaded Successfully")
                            else ("Download failed")
                        }
                });*@

                console.log(STRMS);
            }
        });

        $('#mastersearch').focusout( function () {
            console.log('in=>'+$('#mastersearch').text())
        })

        $("#ClinicID").change(function () {
            var ClinicID = $('#ClinicID').val();
            getProviders(ClinicID);
        });

        function getProviders(ClinicID) {

            if (ClinicID == "") { ClinicID = -1; }
            var json = { "ClinicID": ClinicID };
            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '/Dictators/GetProviders',
                async: true,
                data: JSON.stringify(json),
                success: function (data) {
                    GetDropdown("DictatorID", data, true);
                },
                error: function (err) { console.log(err); }
            });
        }
        function UpdateStatus(FileID) {
            let qID = FileID || 0;
            if (qID > 0) {

                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: '/UploadFiles/UpdateStatus?FileID=' + qID,
                    async: true,
                    success: function (data) {
                    }
                });
            }
        }

        function DownLoadSelectedItems(selectedItems) {
            if (selectedItems.count() == 0) {
                 swal({
                   title: "Download Dictations",
                   text: "Warning:Please select item(s)!",
                   icon: "warning",
                   button: "Okay"
               });
            } else {
                let param = '';
                selectedItems.data().each(function (value, index) {
                    let id = value[0].substring(57, value[0].length - 2);
                    param += `STRMSelected[${index}]=` + id + `&`;
                });
                param = param.substring(0, param.length - 1);
                var url = '@Url.Action("DownloadFiles", "UploadFiles")?' + param;
                window.open(url, "_blank");
            }
        }

        function ConfDelDictation(btn) {
            swal({
                title: "Confirm Delete!",
                text: "Are you sure you want to delete this dictation?",
                icon: "warning",
                buttons: true,
                dangerMode: true,
                }).then((willDelete) => {
                    if (willDelete) {
                        let fileId =  parseInt(btn.value);
                        $.ajax({
                            type: "POST",
                            contentType: "application/json; charset=utf-8",
                            url: '/UploadFiles/RemoveDictation?FileID=' + fileId,
                            async: true,
                            success: function (data) {
                                if (data == true) {
                                    swal("Dictation file has been deleted!", {
                                        icon: "success",
                                        button: "Okay"
                                    }).then((e) => {
                                        $("#btnSearch").click();
                                    });
                                } else {
                                    swal({
                                        title: "Delete Failed!",
                                        text: data,
                                        icon: "error",
                                        button: "Okay"
                                    });
                                }
                            },
                            error: function (xhr, status) {
                                console.log(xhr);
                            }
                        });
                    }
                //    else {
                //    swal("Dictation file is safe!");
                //}
                });
            //alert(btn.value);
        };

        function BulkDelete(selectedItems) {
            if (selectedItems.count() == 0) {
                swal({
                    title: "Warning: Please Select!",
                    text: "Please select dictation(s) to Delete!",
                    icon: "warning",
                    button: "Okay"
                });
                return;
            }
            swal({
                title: "Confirm Delete!",
                text: "Are you sure you want to delete these dictations?",
                icon: "warning",
                buttons: true,
                dangerMode: true,
            }).then((willDelete) => {
                if (willDelete) {
                    $('.Loader').show();

                    let param = '';
                    selectedItems.data().each(function (value, index) {
                        let id = value[0].substring(57, value[0].length - 2);
                        param += `` + id + `,`;
                    });

                    param = param.substring(0, param.length - 1);

                    $.ajax({
                        type: "POST",
                        contentType: "application/json; charset=utf-8",
                        url: '/UploadFiles/BulkRemove?DicIds=' + param,
                        async: true,
                        success: function (response) {
                            if (response.result != undefined) {
                                swal(response.result, {
                                    icon: "success",
                                    button: "Okay"
                                }).then((e) => {
                                    $("#btnSearch").click();
                                });
                            } else {
                                swal({
                                    title: "Delete Failed!",
                                    text: response,
                                    icon: "error",
                                    button: "Okay"
                                });
                            }
                            $('.Loader').hide();

                        },
                        error: function (xhr, status) {
                            console.log(xhr);
                            $('.Loader').hide();

                        }
                    });
                }
            });
        };
    </script>
}
