            console.log("test");
            var FileIDs = [];
            var TypistIDs = [];

            $('#example tbody tr').each(function (i, n) {
                var $row = $(n);

                    FileIDs.push($row.find('input[FileID="FileID"]').val());
                    //TypistIDs.push($row.find('input[TypistId="TypistId"]').val());

                console.log(i);
                console.log(n);
            });

             $.ajax({
                    type: "POST",
                    url: '@Url.Action("TypistRole", "UploadFiles")',
                    contentType: "application/json; charset=utf-8",
                 data: JSON.stringify({ 'FileIDs': FileIDs }),
                    success:
                        function (data) {
                            if (data == true)
                                alert("Downloaded Successfully")
                            else ("Download failed")
                        }
             });
        });*@
    </script>
}
