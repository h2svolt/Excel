@model IEnumerable<ExcelTranscript.Models.stp_GetDictations_Result>
@using ExcelTranscript.Models;
@{
    //commented as it's redundant
    var db = new db_ExcelTransEntities();

}
<style>
    .clicked {
        background-color: white;
    }
</style>

<div class="box-shadow mt-3">

    @if (Model != null)
    {
        int serialNo = 1;

        int minutes = 0;
        int seconds = 0;

        <div class="table-responsive">

            <table id="example" class="table table-responsive table-striped table-bordered nowrap w-100">
                <thead>
                    <tr>
                        <th>
                            &nbsp; @Html.CheckBox("CheckAll", false, new { id = "select_all" })
                            <label for="select_all"> All  </label>                             &nbsp;
                        </th>
                        <th>
                            &nbsp; S. No &nbsp;
                        </th>
                        <th style="min-width: 175px;">Clinic</th>
                        <th style="min-width: 100px;">Provider</th>
                        <th style="min-width: 100px;">Typist</th>
                        <th style="min-width: 175px;">Dictation Name</th>
                        <th style="min-width: 100px;">Duration</th>
                        <th style="min-width: 175px;">Upload Date & Time</th>
                        <th style="min-width: 175px;">Action(s)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @*<input type="checkbox" class="checkbox" onchange="CheckedIDs(this,@item.FileID)" />*@
                                <input type="hidden" name="fileID" class="fileID" value="@item.FileID" />
                                @*<input type="checkbox" class="checkbox" value="@item.FileID" id="@item.FileID" />*@
                            </td>
                            <td>
                                <span>
                                    @serialNo
                                </span>
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ClinicName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Provider)
                            </td>
                            <td>
                                @{
                                    string typistName = "N/A";
                                    var typist = db.AspNetUsers.Where(u => u.UserId == item.TypistAssignID).FirstOrDefault();
                                    if (typist != null)
                                    {
                                        typistName = typist.UserName;
                                    }
                                }
                                @typistName
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.FileName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelitem => item.Duration)
                                @*@(Convert.ToInt32(item.Size) / 1000)*@
                            </td>
                            <td>
                                @Convert.ToString(string.Format("{0:MM/dd/yyyy hh:mm:ss tt}", item.UploadOn))
                            </td>

                            <td>
                                @*<a href="@Url.Content(item.FilePath)" download> Download </a>*@
                                @*<input type="hidden" id="FileID" value="@item.FileID" />*@
                                @*<a  href="@Url.Content(item.FilePath)" id="btnStatus" download> Download </a>*@
                                @if (item.isDownloaded)
                                {
                                    <span class="text-success font-weight-bold">Downloaded</span>
                                }
                                else if (!string.IsNullOrEmpty(item.FilePath))
                                {
                                    <a href="@Url.Content(item.FilePath)" onclick="UpdateStatus(@item.FileID)" download class="btn btn-link btn-sm"> Download </a>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                {
                                    <span>|</span>
                                    <button class="btn btn-sm btn-danger" type="button" value="@item.FileID" onclick="ConfDelDictation(this)"> Delete </button>
                                }
                            </td>

                            @*<td>
                                    @Html.ActionLink("Edit", "Edit", new { id = item.ClinicID }) |
                                    @Html.ActionLink("Details", "Details", new { id = item.ClinicID }) |
                                    @Html.ActionLink("Delete", "Delete", new { id = item.ClinicID })
                                </td>*@
                        </tr>

                        serialNo++;
                        if (!string.IsNullOrWhiteSpace(item.Duration))
                        {
                            var dp = item.Duration.Split(':');
                            int hh = 0, mm = 0, ss = 0;
                            if (dp.Length == 3) { int.TryParse(dp[0], out hh); int.TryParse(dp[1], out mm); int.TryParse(dp[2], out ss); }
                            else if (dp.Length == 2) { int.TryParse(dp[0], out mm); int.TryParse(dp[1], out ss); }
                            minutes += hh * 60 + mm;
                            seconds += ss;
                        }

                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="6"></td>
                        <td>

                            @{
                                TimeSpan audioDuration = new TimeSpan(0, minutes, seconds);
                            }
                            <span class="font-weight-bold">
                                @audioDuration.Duration()
                            </span>
                        </td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
    else
    {
        <text>
            <script type="text/javascript">
                swal("No Data", "No Data Found!", "error");
            </script>
        </text>
    }
</div>

@section scripts{

    @*<link rel="stylesheet" type="text/css" href="~/Content/vendors/css/extensions/sweetalert.css">
        <script src="~/Scripts/vendor/js/extensions/sweetalert.min.js" type="text/javascript"></script>*@


    <script type="text/javascript">


        $('.star').click(function () {
            $(this).toggleClass('clicked');
        });
                        //var col = [1, 2, 3, 4, 5, 6, 7, 8, 9]
                        //GetTableData(col, 0, "desc");
    </script>



}
