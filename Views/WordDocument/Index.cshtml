@using ExcelTranscript.Models;

@{
    Layout = null;
    db_ExcelTransEntities db = new db_ExcelTransEntities();
    bool? isDocApproved = false;

    if (Request.QueryString["DocID"] != null && Request.QueryString["FilePath"] != null)
    {
        var id = Request.QueryString["DocID"].ToString() == "" ? 0 : Convert.ToUInt32(Request.QueryString["DocID"]);
        var name = Request.QueryString["FilePath"].ToString() == "" ? "" : Request.QueryString["FilePath"];

        if (id != 0)
        {
            var filename = name.Split('.').FirstOrDefault();
            var DocApproved = db.UploadedDocuments.Where(d => d.Id == id).FirstOrDefault();
            var uploadedFile = db.UploadedFiles.Where(f => f.FileID == DocApproved.FileID && f.FileName == filename).FirstOrDefault();
            if (DocApproved != null)
            {
                if (DocApproved.IsApproved.HasValue)
                {
                    isDocApproved = DocApproved.IsApproved;
                }
                else
                {
                    if (DocApproved.StatusId == 5)
                    {
                        isDocApproved = true;
                    }
                }
            }
            else if (DocApproved == null && uploadedFile != null)
            {
                if (uploadedFile.StatusId == 5)
                {
                    isDocApproved = true;
                }
            }
            else
            {
                isDocApproved = false;
            }
        }

    }
}
