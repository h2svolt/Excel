<script>

        @*function LeaveReviewFunc() {
            var textareadata = $("#txtEditor").val();
      window.localtion.href='@Url.Action("SaveDocument", "WordDocument", new { FileText : textareadata })';
  }*@

    function OpenDocument(v) {
        $('.Loader').show();
            console.log(txtEditor);
        var value = $("#v").val();
            var FileText = $(".Editor-editor").html();
            var HideText = $("#HideHtml").html();
            console.log(HideText);
            console.log(FileText);
            var params = { 'FileText': FileText, 'HideText': HideText,'value' : v};

            $.ajax({
                url: '/WordDocument/SaveDocument',
                data: JSON.stringify(params),
                type: 'POST',
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                success: function (result) {
                    if (result == true) {
                        $('.Loader').hide();
                        Swal.fire({
                            position: 'center',
                            icon: 'success',
                            title: 'Successfully Updated!',
                            showConfirmButton: true
                        }).then((result) => {
                            location.reload();
                        });
                        
                    }
                    else {
                        $('.Loader').hide();
                        Swal.fire({
                            position: 'center',
                            icon: 'warning',
                            title: result,
                            showConfirmButton: true,
                            timer: 5000
                        });
                    }
                },

                error: function (response) {
                    alert(response);
                }
            });
            return false;
        }
</script>

