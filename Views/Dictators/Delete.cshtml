@model ExcelTranscript.Models.Dictator

@{
    ViewBag.Title = "Delete";
}

<h3>Are you sure you want to delete this?</h3>
<section class="content">

    <!-- *========== Main Heading ========== -->
    @*<div class="pt-3 pb-2">
            <div class="container-fluid">
                <h2 class="main-heading">Add Clinic</h2>
            </div>
        </div>*@

    <!-- *========== Breadcrumbs ========== -->
    <div>
        <div class="container-fluid">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-white px-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dictators")">Home</a></li>
                    <li class="breadcrumb-item active">Edit Dictator</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- *========== Form ========== -->
    <div class="py-3">
        <div class="container">
            <div class="row">
                <div class="col-md-10 m-auto">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="form-title pb-2"><i class="fa fa-user-o" aria-hidden="true"></i> Login Information</h4>
                            </div>
                            <div class="col-md-6 py-2">
                                <div class="form-group">
                                    <label for="name">System ID</label>
                                    @Html.EditorFor(model => model.SystemID, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                </div>
                            </div>
                            <div class="col-md-6 py-2">
                                <div class="form-group">
                                    <label for="Clinic Name">Clinic Name</label>
                                    @Html.EditorFor(model => model.Clinic.Name, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.Clinic.Name, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="address">Login ID</label>
                                    @Html.EditorFor(model => model.LoginID, new { htmlAttributes = new { @class = "form-control" ,@readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.LoginID, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="city">Password</label>
                                    @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-2 py-2">
                                <div class="form-group">
                                    <label for="state">Confirm Password</label>
                                    @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-2 py-2">
                                <div class="form-group">
                                    <label for="country">All Client Access</label>
                                    @Html.CheckBoxFor(x => x.AllClientAccess)
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="form-title pb-2"><i class="fa fa-user-o" aria-hidden="true"></i> Personal Information</h4>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="account_Id">Prefix</label>
                                    @Html.DropDownList("Prefix", new List<SelectListItem>{
                                                  new SelectListItem{ Text="Select", Value = "0" },
                                                  new SelectListItem{ Text="Dr", Value = "Dr" },
                                                  new SelectListItem{ Text="Mr", Value = "Mr" },
                                                  new SelectListItem{ Text="Ms", Value = "Ms" },
                                                  new SelectListItem{ Text="Mrs", Value = "Mrs" },
                                              }, htmlAttributes: new { @class = "form-control", @readonly = "readonly" })
                                    @Html.ValidationMessageFor(model => model.Prefix, "", new { @class = "text-danger"  })
                                </div>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="name">First Name</label>
                                    @Html.EditorFor(model => model.FirstName, new { htmlAttributes = new { @class = "form-control" , @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.FirstName, "", new { @class = "text-danger" })

                                </div>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="name">Middle Name</label>
                                    @Html.EditorFor(model => model.MiddleName, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.MiddleName, "", new { @class = "text-danger" })

                                </div>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="name">Last Name</label>
                                    @Html.EditorFor(model => model.LastName, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-danger" })

                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="form-title pb-2"><i class="fa fa-user-o" aria-hidden="true"></i> Professional Information</h4>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="account_Id">Speciality</label>
                                    @Html.EditorFor(model => model.Speciality.Name, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.SpecialityID, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="Secretary">Secretary</label>
                                    @Html.EditorFor(model => model.SecretaryName, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.SecretaryName, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="name">Is Fax</label>
                                    @Html.CheckBoxFor(x => x.IsFax)
                                </div>
                            </div>
                            <div class="col-md-3 py-2">
                                <div class="form-group">
                                    <label for="name">Review</label>
                                    @Html.CheckBoxFor(x => x.IsReview)
                                </div>
                            </div>
                            <div class="col-md-2 py-2">
                                <div class="form-group">
                                    <label for="NoOfLine">No Of Lines</label>
                                    @Html.EditorFor(model => model.NoOfLine, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.NoOfLine, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="form-title pb-2">
                                    <i class="fa fa-user-o" aria-hidden="true"></i> Contact Information
                                </h4>
                            </div>
                            <div class="col-md-4 py-2">
                                <div class="form-group">
                                    <label for="pName">Name</label>
                                    @Html.EditorFor(model => model.CP_Name, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.CP_Name, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-4 py-2">
                                <div class="form-group">
                                    <label for="phone">Phone</label>
                                    @Html.EditorFor(model => model.CP_Phone, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.CP_Phone, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-4 py-2">
                                <div class="form-group">
                                    <label for="cell">Cell</label>
                                    @Html.EditorFor(model => model.CP_Cell, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.CP_Cell, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-4 py-2">
                                <div class="form-group">
                                    <label for="address">Address</label>
                                    @Html.EditorFor(model => model.CP_Address, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.CP_Address, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-4 py-2">
                                <div class="form-group">
                                    <label for="email">Email</label>
                                    @Html.EditorFor(model => model.CP_Email, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.CP_Email, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-4 py-2">
                                <div class="form-group">
                                    <label for="pager">Pager</label>
                                    @Html.EditorFor(model => model.CP_Pager, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                                    @Html.ValidationMessageFor(model => model.CP_Pager, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <div class="divider"></div>
                        <div class="row">
                            <div class="col-md-12 pt-2">
                                <input type="submit" value="Delete" class="form-btn mr-2" />
                                <button type="button" class="form-btn mr-2" onclick="location.href='@Url.Action("Index", "Dictators")'">
                                    <i class="fa fa-times" aria-hidden="true"></i>
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
