        function GetDictatorDetails(DictatorID) {
            console.log(DictatorID);
            let qID = DictatorID || 0;
            if (qID > 0) {

                $.ajax({
                    type: "GET",
                    contentType: "application/json; charset=utf-8",
                    url: '/Dictators/GetDictatorsDetails?DictatorID=' + qID,
                    async: true,
                    success: function (data) {
                        // console.log(data);
                        //$("#FileID").text(StrCode);
                        $("#revisedTable tbody").empty();

                        for (var i = 0; i < data.length; i++) {
                            let name = data[i].Name == null ? '-' : data[i].Name;
                            let Phone = data[i].Phone == null ? '-' : data[i].Phone;
                            let Cell = data[i].Cell == null ? '-' : data[i].Cell;
                            let Address = data[i].Address == null ? '-' : data[i].Address;
                            let Email = data[i].Email == null ? '-' : data[i].Email;
                            let Pager = data[i].Pager == null ? '-' : data[i].Pager;
                            var markup = "<tr>\
                                            <td hidden> "+ data[i].DictatorID + " </td> \
                                            <td> "+ name + " </td> \
                                            <td> "+ Phone + " </td> \
                                            <td> "+ Cell + " </td> \
                                            <td> "+ Address + " </td> \
                                            <td> "+ Email + " </td> \
                                            <td> "+ Pager + " </td> \
                                            </tr>";

                            $("#revisedTable tbody").append(markup);
                        }
                    },
                    error: function (err) { console.log(err); }
                });
            }
        }

        $(document).ready(function () {
                var message = '@ViewBag.message';
                if (message === 'Added')
                {
                    swal('Provider added successfully', 'Excel Transcript', 'success');
                    window.history.pushState({}, document.title, window.location.pathname);
                }
                else if (message === 'Edited')
                {
                    swal('Provider updated successfully', 'Excel Transcript', 'success');
                    window.history.pushState({}, document.title, window.location.pathname);
                }
