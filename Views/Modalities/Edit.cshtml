@model ExcelTranscript.Models.Modality

@{
    ViewBag.Title = "Edit";
}

<div class="container my-4">

    @using (Html.BeginForm("Edit", "Modalities", FormMethod.Post, new { @class = "" }))
    {
        @Html.AntiForgeryToken()

        <div class="">
            <h4>Edit Modality</h4>
            <hr />

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.HiddenFor(model => model.Id)

            <div class="form-group">
                <label class="control-label col-md-4 px-0"> Modality Name</label>
                <div class="col-md-6 px-0">
                    @Html.EditorFor(model => model.ModalityName, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.ModalityName, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="divider"></div>
            <div class="row">
                <div class="col-md-12 pt-2">
                    <input type="submit" value="Save" class="form-btn mr-2" />
                    <button type="button" class="form-btn-cancel mr-2 btn-warning" onclick="location.href='@Url.Action("Index", "Modalities")'">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }

</div>
<div class="container">
    <div>
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-link px-0" })
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
