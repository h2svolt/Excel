<!DOCTYPE html>
<html>
<head>
    <title>Audio Recorder</title>
    <style>
        /* styles.css */

      

    </style>
</head>
@{
    ViewBag.title = "Upload File";
    var Dictatorlst = ViewBag.DictatorID;
}
<body>
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="text-center">
                    @Html.DropDownList("DictatorID", new SelectList(ViewBag.DictatorID, "value", "Text"), new { @class = "form-control", @Disabled = "Disabled", @Hidden = "hidden" })

                    <h1>Audio Recorder</h1>
                    <input type="text" name="name" class="form-control" placeholder="File Name" id="name" value="" />
                    <button id="start" class="btn btn-primary mt-3">Start Recording</button>
                    <button id="stop" class="btn btn-danger mt-3">Stop Recording</button>
                    <button id="save" class="btn btn-primary mt-3">Save Recording</button>
                    <button id="play" hidden class="btn btn-success mt-3">Play Recording</button>
                    <button id="reset" class="btn btn-secondary mt-3">Reset</button>
                    <button id="download" class="btn btn-info mt-3">Download WAV</button>

                    <div id="timer" class="mt-3">00:00</div>
                    <audio id="audioPlayer" controls class="mt-3"></audio>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>


        $(document).ready(function () {
            const startButton = document.getElementById("start");
            const stopButton = document.getElementById("stop");
            const playButton = document.getElementById("play");
            const saveButton = document.getElementById("save");
            const resetButton = document.getElementById("reset");
            const audioPlayer = document.getElementById("audioPlayer");
            const timerElement = document.getElementById("timer");
            const downloadButton = document.getElementById("download");


            let audioChunks = [];
            let lastAudio = [];
            let mediaRecorder;
            let timerInterval;
            let startTime;

            downloadButton.addEventListener("click", () => {
                if (lastAudio.length > 0) {
                    const audioBlob = new Blob(lastAudio, { type: "audio/wav" });
                    const audioUrl = URL.createObjectURL(audioBlob);

                    // Create a temporary anchor element to trigger the download
                    const tempAnchor = document.createElement("a");
                    tempAnchor.href = audioUrl;
                    tempAnchor.download = "recorded_audio.webm";
                    tempAnchor.click();

                    // Clean up the temporary anchor
                    URL.revokeObjectURL(audioUrl);
                }
            });

            saveButton.addEventListener("click", (e) => {
                if (lastAudio.length > 0) {
                    const dictId = $("#DictatorID").val();
                    const time = $("#timer").html()
                    const fileName = $("#name").val()
                    debugger;
                    const audioBlob = new Blob(lastAudio, { type: "audio/wav" });

                    const formData = new FormData();
                    formData.append("audioFile", audioBlob, fileName+".wav");

                    $.ajax({
                        type: "POST",
                        url: "/UploadFiles/SingleUploadAsync?DictatorID=" + dictId + "&duration=" + time,
                        data: formData,
                        processData: false,
                        contentType: false,
                        success: function (response) {
                            alert(response.message); // Display a message to the user
                            window.location.href = "/UploadFiles"
                        },
                        error: function (error) {
                            console.error("Error uploading audio: ", error);
                        }
                    });
                } else {
                    alert("No recorded audio to save.");
                }
            });

            startButton.addEventListener("click", async () => {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);

                mediaRecorder.ondataavailable = event => {
                    if (event.data.size > 0) {
                        audioChunks.push(event.data);
                    }
                };

                mediaRecorder.onstop = () => {
                    clearInterval(timerInterval);
                    const audioBlob = new Blob(audioChunks, { type: "audio/wav" });
                    const audioUrl = URL.createObjectURL(audioBlob);
                    audioPlayer.src = audioUrl;
                    lastAudio = audioChunks;
                    audioChunks = [];
                    audioPlayer.load();
                };

                mediaRecorder.start();
                startTime = Date.now();
                startTimer();
            });

            stopButton.addEventListener("click", () => {
                mediaRecorder.stop();
            });

            resetButton.addEventListener("click", () => {
                clearInterval(timerInterval);
                timerElement.textContent = "00:00";
                if (mediaRecorder && mediaRecorder.state === "recording") {
                    mediaRecorder.stop();
                }
                audioChunks = [];
                audioPlayer.pause();
            });

            function startTimer() {
                timerInterval = setInterval(updateTimer, 1000);
            }

            function updateTimer() {
                const currentTime = Date.now();
                const elapsedTime = Math.floor((currentTime - startTime) / 1000);
                const minutes = Math.floor(elapsedTime / 60).toString().padStart(2, "0");
                const seconds = (elapsedTime % 60).toString().padStart(2, "0");
                timerElement.textContent = `${minutes}:${seconds}`;
            }
        });


    </script>
</body>
</html>
