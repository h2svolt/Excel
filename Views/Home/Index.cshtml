        function GetAudioDocuments(AudioID) {
            let qID = AudioID || 0;
            console.log(qID);
            if (qID > 0) {
                var isTypist = '@User.IsInRole("Typist")';
                $.ajax({
                    type: "GET",
                    contentType: "application/json; charset=utf-8",
                    url: '/UploadFiles/GetDocumentCounts?AudioID=' + qID,
                    async: true,
                    success: function (data) {
                        $("#revisedTable tbody").empty();
                        for (var i = 0; i < data.length; i++) {
                            console.log(data[i].UploadOn);
                            var date = new Date(data[i].Uploaded);
                            console.log(date);

                            var bgcolor= "white"

                            if (data[i].DocChildID) {
                                bgcolor = "paleturquoise";
                            }

                            var markup = "<tr style='background-color:" + bgcolor +"'>\
                                            <td hidden> "+ data[i].DocId + " </td> \
                                            <td> "+ data[i].FileName + " </td> \
                                            <td> "+ data[i].Uploaded + " </td> \
                                            <td> <a href='"+ data[i].FilePath +"' download> Download </a> </td> \
                                            <td> <a target='_blank' href='/WordDocument/Index?FilePath="+ data[i].FileName + "." + data[i].ext + "&DocID=" + data[i].DocId +"'> View </a> </td> \
                                            <td> <a class='FaxOption' href='/WordDocument/UploadFax?FileName="+ data[i].FileName + "." + data[i].ext+"'> Fax </a> </td> \
                                            </tr>";

                            $("#revisedTable tbody").append(markup);
                        }

                        if (isTypist === "True") {
                            $('.FaxOption').addClass('d-none');
                        }
                    },
                    error: function (err) { console.log(err); }
                });
            }
        }

