@model IEnumerable<ExcelTranscript.Models.Speciality>

@{
    ViewBag.Title = "Speciality List";
}

<section class="content">

    <!-- *========== Main Heading ========== -->
    @*<div class="pt-3 pb-2">
            <div class="container-fluid">
                <h2 class="main-heading">Clinic List</h2>
            </div>
        </div>*@

    <!-- *========== Breadcrumbs ========== -->
    <div>
        <div class="container-fluid">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-white px-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Specialities")">Home</a></li>
                    <li class="breadcrumb-item ">Clinic</li>
                    <li class="breadcrumb-item active">@ViewBag.Title </li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- *========== Data Table ========== -->
    <div class="p-3 px-5">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">
                    <table id="example" class="table table-striped table-bordered" style="width:100%">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th></th>
                            </tr>

                        </thead>
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @Html.DisplayFor(modelItem => item.Name)
                                </td>
                                <td>
                                    @Html.ActionLink("Edit", "Edit", "Specialities", new { id = item.SpecialityID }, new { @class = "btn btn-primary", @style = "font-size:12px" })
                                    @Html.ActionLink("Delete", "Delete", "Specialities", new { id = item.SpecialityID }, new { @class = "btn btn-danger", @style = "font-size:12px" })
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>


@section scripts{
    <script type="text/javascript">

        $(document).ready(() => {
            var message = '@ViewBag.message';
            if (message === 'Added')
            {
                swal({
                    title: "New speciality added, successfully!",
                    text: "",
                    icon: "success",
                    timer: 2500,
                });
            }
            else if (message === 'Edited')
            {
                swal({
                    title: "Speciality details updated, successfully!",
                    text: "",
                    icon: "success",
                    timer: 2500,
                });
            }
            else if (message === 'Deleted')
            {
                swal({
                    title: "Speciality removed!",
                    text: "",
                    icon: "info",
                    timer: 2500,
                });
            }
            window.history.pushState({}, document.title, window.location.pathname);
        });
    </script>
}

