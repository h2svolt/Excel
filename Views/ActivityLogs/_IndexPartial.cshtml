@model IEnumerable<ExcelTranscript.Models.stp_GetDocumentsDataNew_Result>
@using ExcelTranscript.Models;

@{
    var db = new db_ExcelTransEntities();
    var objLog = db.UserLogs.ToList();
}


<div class="box-shadow mt-3">

    @if (Model != null || Model.Count() > 0)
    {
        <div class="table-responsive" >
            <table id="example" class="table table-striped table-bordered alt-pagination">
                <thead>
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col" hidden>Audio ID</th>
                        <th scope="col">Provider</th>
                        <th scope="col">File Name</th>
                        <th scope="col">Duration</th>
                        <th scope="col">Last Updated On</th>
                        <th scope="col">Time</th>
                        <th scope="col">Status</th>
                        <th scope="col">Activity Log</th>
                    </tr>
                </thead>
                <tbody>
                    @{int index = 1;}
                    @foreach (var item in Model)
                    {
                        var status = db.UserLogs.Where(x => x.DocID == item.DocumentId && x.FileName == item.DocumentName && x.AudioID == item.AudioID).OrderByDescending(x => x.Id).FirstOrDefault();
                        var Action = status.Action == 1 ? "Dictation Uploaded" : status.Action == 0 ? "Downloaded" :
                         status.Action == 2 ? "Assigned" : status.Action == 7 ? "Faxed" :
                         status.Action == 4 ? "Archived" : status.Action == 5 ? "Approved" :
                         status.Action == 8 ? "Document Uploaded" : "";

                        <tr style="background-color: @item.Status">
                            <td>
                                @index
                            </td>
                            <td hidden>
                                @Html.DisplayFor(modelItem => item.AudioID)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Provider)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.DocumentName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Duration)
                            </td>
                            <td>
                                @Convert.ToString(string.Format("{0:MM/dd/yyyy}", status.Date))
                            </td>
                            <td>
                                @Convert.ToString(string.Format("{0:hh:mm:ss tt}", status.Date))
                            </td>
                            <td>
                                @*@Html.DisplayFor(modelitem => item.Status)*@
                                @Action
                            </td>
                            <td scope="row">
                                @if (objLog.Where(sa => sa.DocID == item.DocumentId).Count() > 0)
                                {
                                    int a = objLog.Where(sa => sa.DocID == item.DocumentId).Count();
                                    int b = objLog.Where(x => x.FileType != "doc" && x.FileType != "docx" && x.AudioID == item.AudioID).Count();
                                    int count = a + b;
                                    <button class="btn btn-success" type="button" data-toggle="modal" data-target="#ActivityLogsModal" onclick="GetActivityLogs(@item.DocumentId, @item.AudioID)">
                                        @count
                                    </button>

                                }
                                else
                                {
                                    <button class="btn btn-danger">
                                        @(objLog.Where(sa => sa.DocID == item.DocumentId).Count())
                                    </button>

                                }
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <text>
            <script type="text/javascript">
                swal("No Data", "No Data Found!", "error");
            </script>
        </text>
    }

    @*<-- Modal working -->*@

    <div class="modal fade" id="ActivityLogsModal" tabindex="-1" role="dialog" aria-labelledby="ActivityLogsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    @*<h5 class="modal-title" id="ActivityLogModalLabel"> <p><text id="quoteOldID"></text></p></h5>*@
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <table id="revisedTable" class="table table-striped table-bordered alt-pagination">
                        <thead>
                            <tr>
                                @*<th hidden> Id </th>*@
                                @*<th> File Name </th>*@
                                @*<th> Provider </th>*@
                                <th> Action by </th>
                                <th> Date </th>
                                <th> Time </th>
                                <th> Action </th>
                                <th> File Type </th>
                                @*<th>  </th>*@
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

</div>

