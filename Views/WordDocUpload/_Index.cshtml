@model IEnumerable<ExcelTranscript.Models.stp_GetDocuments_Result>
@using ExcelTranscript.Models;
@{
    var db = new db_ExcelTransEntities();
    var objDoc = db.UploadedDocuments.ToList();
    var obj = db.Modalities.ToList();
    var applicationUsers = db.AspNetUsers.ToList();

}
<style>
    .clicked {
        background-color: white;
    }
</style>


<div class="box-shadow mt-3">

    @if (Model != null)
    {
        int serialNo = 1;
        <div class="table-responsive">

            <table id="example" class="table table-striped table-responsive table-bordered nowrap" style="width:100%">
                <thead>
                    <tr>
                        <th>
                            @Html.CheckBox("CheckAll", false, new { id = "select_all" })
                            <label for="select_all"> All  </label>
                        </th>
                        <th>
                            S. No
                        </th>
                        <th style="min-width: 100px;">Clinic</th>
                        <th style="min-width: 100px;">Provider</th>
                        <th style="min-width: 100px;">Typist</th>
                        <th style="min-width: 175px;">Document Name</th>
                        <th style="min-width: 100px;">Document Status</th>
                        <th style="min-width: 175px;">Patient Name</th>
                        <th style="min-width: 100px;">Upload Date</th>
                        <th style="min-width: 175px;">&nbsp;&nbsp; Modalities &nbsp;&nbsp;</th>
                        <th style="min-width: 100px;"> Set Modality </th>
                        <th style="min-width: 100px;"> Fax Status </th>
                        <th style="min-width: 100px;">Action(s)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {

                        string RowColor;
                        string bgColor;
                        var docStatus = db.Status.Where(s => s.Name == item.Status).FirstOrDefault();

                        if (item.ModalityId == null || item.ModalityId == 0)
                        {
                            RowColor = "Red";
                        }
                        else
                        {
                            RowColor = "Green";
                        }

                        if (docStatus == null)
                        {
                            var audStatus = db.UploadedFiles.Where(d => d.FileID == item.AudioFileID).FirstOrDefault();
                            bgColor = audStatus.Status.Color;
                            item.Status = audStatus.Status.Name;
                        }
                        else
                        {
                            bgColor = docStatus.Color;
                        }

                        <tr style="background-color:@bgColor.ToString() !important;">
                            <td>
                                @*@onchange = "getIDs(this.value," + item.AudioID + ")"*@
                                @*<input type="checkbox" class="checkbox" onchange="CheckedIDs(this,@item.Id)" />*@
                                <input type="hidden" name="fileID" class="fileID" value="@item.Id" />
                                @*<input type="checkbox" class="checkbox" value="@item.Id" id="selectedid" />*@
                            </td>
                            <td>
                                <span>
                                    @serialNo
                                </span>
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ClinicName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Provider)
                            </td>
                            <td>
                                @{
                                    string typistName = "";
                                    var typist = applicationUsers.Where(u => u.UserId == item.TypistAssignID).FirstOrDefault();
                                    if (typist != null)
                                    {
                                        typistName = typist.UserName;
                                    }
                                    else
                                    {
                                        typistName = "N/A";
                                    }
                                }
                                @typistName
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.FileName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Status)
                            </td>
                            <td>
                                @{ item.PatientName = string.IsNullOrWhiteSpace(item.PatientName) ? "N/A" : item.PatientName;

                                }@item.PatientName
                            </td>
                            <td>
                                @Convert.ToString(string.Format("{0:MM/dd/yyyy}", item.UploadOn))
                            </td>
                            <td>
                                <span></span>
                                @Html.DropDownListFor(m => item.ModalityId, new SelectList(ViewBag.Modality, "value", "text"), item.ModalityId != null ? obj.Where(sa => sa.Id == item.ModalityId).FirstOrDefault().ModalityName : "Select Modality", htmlAttributes: new { @class = "select2 form-control" })
                            </td>
                            <td class="text-center">
                                <span class="fa fa-check"
                                      style="height:5px;color:@RowColor;font-size:large;margin-left:5px;margin-top:8px"
                                      id="CheckId" aria-hidden="false" title="Save selected modality."
                                      onclick="CheckMark(this,@item.Id)">
                                </span>
                            </td>
                            <td>
                                @{
                                    string faxStatus = "";
                                    var tbl_faxStatus = db.FileFaxStatus.Where(f => f.UpDocID == item.Id).FirstOrDefault();
                                    if (tbl_faxStatus != null)
                                    {
                                        faxStatus = tbl_faxStatus.Status;
                                    }
                                    else
                                    {
                                        faxStatus = "N/A";
                                    }
                                }
                                @faxStatus
                            </td>
                            <td>
                                @*<a href="@Url.Content(item.FilePath)" download> Download </a>*@
                                <button onclick="DownloadFile(@item.Id)" class="btn btn-link btn-sm"> Download </button>
                                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                {
                                    <span>|</span>
                                    <button class="btn btn-sm btn-danger" type="button" onclick="ConfDelDictation(@item.Id)"> Delete </button>
                                }
                            </td>

                            @*<td>
                                    @Html.ActionLink("Edit", "Edit", new { id = item.ClinicID }) |
                                    @Html.ActionLink("Details", "Details", new { id = item.ClinicID }) |
                                    @Html.ActionLink("Delete", "Delete", new { id = item.ClinicID })
                                </td>*@
                        </tr>

                        serialNo++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <text>
            <script type="text/javascript">
                swal("No Data", "No Data Found!", "error");
            </script>
        </text>
    }
</div>

@section scripts{

    @*<link rel="stylesheet" type="text/css" href="~/Content/vendors/css/extensions/sweetalert.css">
        <script src="~/Scripts/vendor/js/extensions/sweetalert.min.js" type="text/javascript"></script>*@


    <script type="text/javascript">



        $('.star').click(function () {
            $(this).toggleClass('clicked');
        });
                                                                            //var col = [1, 2, 3, 4, 5, 6, 7, 8, 9]
                                                                            //GetTableData(col, 0, "desc");
    </script>



}
