@model ExcelTranscript.Models.Manager

@{
    ViewBag.Title = "Delete";
}
<div class="container mt-4">

    <h2>Delete Manager</h2>

    <h4>Are you sure you want to delete this Manager?</h4>
    <div>        
        <dl class="dl-horizontal">                  
            <dt>
                @Html.DisplayNameFor(model => model.Username)
            </dt>

            <dd class="pl-3">
                @Html.DisplayFor(model => model.Username)
            </dd>

            <dt>
                @Html.DisplayNameFor(model => model.AddedOn)
            </dt>

            <dd class="pl-3">
                @Html.DisplayFor(model => model.AddedOn)
            </dd>

            <dt>
                @Html.DisplayNameFor(model => model.AddedBy)
            </dt>

            <dd class="pl-3">
                @Html.DisplayFor(model => model.AddedBy)
            </dd>

            <dt>
                in Active
            </dt>

            <dd class="pl-3">
                @Html.DisplayFor(model => model.isActive)
            </dd>

        </dl>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-actions no-color">
                <input type="submit" value="Delete" class="btn btn-danger" /> |
                @Html.ActionLink("Back to List", "Index")
            </div>
        }
    </div>
</div>
