@model ExcelTranscript.Models.DTO.ManagerDTO

@{
    ViewBag.Title = "Create Manager Account";
}
      <style>
          .select2-search__field {
              width: 100% !important;
          }
      </style> 
<section class="content">
    <!-- *========== Breadcrumbs ========== -->
    <div>
        <div class="container-fluid">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-white px-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Managers")">Home</a></li>
                    <li class="breadcrumb-item active">Add Manager</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- *========== Form ========== -->
    <div class="py-3">
        <div class="container">
            <div class="row">
                <div class="col-md-10 m-auto">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="form-title pb-2"><i class="fa fa-user-o" aria-hidden="true"></i> Personal Information</h4>
                            </div>
                            <div class="col-md-6 py-2">
                                <div class="form-group">
                                    <label for="address">User Name</label>
                                    @Html.EditorFor(model => model.Username, new { htmlAttributes = new { @class = "form-control", maxlength = "150", minlength = "2" } })
                                    @Html.ValidationMessageFor(model => model.Username, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-6 d-flex justify-content-center mt-4 py-2">
                                <div class="form-check">
                                    @Html.CheckBoxFor(x => x.isActive, new { @class = "form-check-input", @checked="checked" })
                                    <label for="isActive">Is Active</label>
                                </div>
                            </div>
                            <div class="col-md-6 py-2">
                                <div class="form-group">
                                    <label class="control-label">Password</label>
                                    <div class="input-group" id="show_hide_password">
                                        @Html.PasswordFor(modal => modal.Password, new { @class = "form-control", maxlength = "100", minlength = "2" })
                                        <div class="input-group-addon" title="Show Password" style="background: #E8F0FE;padding: 0px 10px;border-radius: 0px 5px 5px 0px;">
                                            <a href=""><i class="fa fa-eye-slash" aria-hidden="true"></i></a>
                                        </div>
                                    </div>
                                    @Html.ValidationMessageFor(modal => modal.Password, "", new { @class = "text-danger col-md-12 mt-1" })
                                </div>
                            </div>
                            <div class="col-md-6 py-2">
                                <div class="form-group">
                                    <label for="confirmPassword">Confirm Password</label>
                                    @Html.Password("confirmPassword", null, new { @class = "form-control", id = "confirmPassword", maxlength = "100", @type = "password", minlength = "2" })
                                    <span class="text-danger" id="notMatchingError"></span>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <h4 class="form-title pb-2">
                                    <i class="fa fa-info" aria-hidden="true"></i>
                                    Rights Information
                                </h4>
                            </div>
                            <div class="col-md-6 py-2">
                                <div class="form-group">
                                    <label >Clinic(s)</label>
                                    @Html.DropDownList("Clinics", new SelectList(ViewBag.Clinics, "id", "text"), htmlAttributes: new { @class = "form-control", @required = "required", multiple = "multiple" })
                                </div>
                            </div>
                            <div class="col-md-6 py-2">
                                <div class="form-group">
                                    <label >Provider(s)</label>
                                    @Html.DropDownList("Dictators", new SelectList(new List<object>(), "id", "text"), htmlAttributes: new { @class = "form-control", @required = "required", multiple = "multiple" })
                                </div>
                            </div>
                        </div>

                        <div class="divider"></div>
                        <div class="row">
                            <div class="col-md-12 pt-2">
                                <input type="button" value="Create" class="form-btn mr-2" id="btnSubmitClient" />                              
                                <button type="button" class="form-btn-cancel mr-2" onclick="location.href='@Url.Action("Index", "Managers")'">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {

    @Scripts.Render("~/bundles/jqueryval")   
    <script>
       
        $(document).ready(function () {
            $('#Dictators').html('').select2({                    
                placeholder: 'No Provider(s) Found.',
            });
            $("#Clinics").select2({
                placeholder: 'Select Clinic(s)',
                allowClear: true,
                sorter: addSelectAllClinics,
                theme: "classic",
            });
            $("#show_hide_password a").on('click', function (event) {
                event.preventDefault();
                if ($('#show_hide_password input').attr("type") == "text") {
                    $('#show_hide_password input').attr('type', 'password');
                    $('#show_hide_password i').addClass("fa-eye-slash");
                    $('#show_hide_password i').removeClass("fa-eye");
                } else if ($('#show_hide_password input').attr("type") == "password") {
                    $('#show_hide_password input').attr('type', 'text');
                    $('#show_hide_password i').removeClass("fa-eye-slash");
                    $('#show_hide_password i').addClass("fa-eye");
                }
            });
        });
        $("#confirmPassword").on('keyup', function (event) {
            var password = $('#Password').val();
            var confirmPassword = $(this).val();
            if (password !== confirmPassword) {
                $('#notMatchingError').show().html('Password and confirm password not matching.');
            } else {
                $('#notMatchingError').hide().html('');
            }
        });
        $("#btnSubmitClient").on('click', function (event) {
            var password = $('#Password').val();
            var confirmPassword = $('#confirmPassword').val();
            if (password !== confirmPassword) {
                $('#notMatchingError').show().html('Password and confirm password not matching.');
                return;
            } else if ($('#Clinics').val().length > 0 && $('#Dictators').val().length <= 0) {
                alert('Please select atleast one Provider!');
            }
            else
            {
                insert();
            }
        });
        
        $('#Clinics').on('change.select2', function (e) {
            if (e.target.selectedOptions.length <= 0) {
                $('#Dictators').html('').select2({
                    data: [{ id: '', text: '' }],
                    placeholder: 'No Provider(s) Found.',
                });
               
            } else {

                const selectedIds = [];
                for (let ind = 0; ind < e.target.selectedOptions.length; ind++) {
                    var selectedID = e.target.selectedOptions[ind].value;
                    selectedIds.push(selectedID);                
                }
                FillProvidersDDL(selectedIds);
            }
        });

        $('#Clinics').on('select2:unselect', function (e) { 
           
            const selectedIds = [];
            for (let ind = 0; ind < e.target.selectedOptions.length; ind++) {
                var selectedID = e.target.selectedOptions[ind].id;
                selectedIds.push(selectedID);                
            }
            FillProvidersDDL(selectedIds);

        });

        const addSelectAllClinics = clinics => {
            if (clinics.length > 0) {
                // Insert a special "Select all clinics" item at the start of the
                // list of clinicclinics items.
                return [
                    { id: 'selectAll', text: 'Select All', Ids: clinics.map(clinic => clinic.id) },
                    ...clinics
                ];
            }
        };


        const handleSelectionClinics = event => {
            if (event.params.data.id === 'selectAll') {
                $('#Clinics').val(event.params.data.Ids);
                $('#Clinics').trigger('change');
            };
        };

        $('#Clinics').on('select2:select', handleSelectionClinics);

        const addSelectAllDictators = items => {
            if (items.length > 0) {
                items.pop();
                return [
                    { id: 'selectAll', text: 'Select All', Ids: items.map(item => item.id) },
                    ...items
                ];
            }
        };

        const handleSelectionDictators = event => {
            if (event.params.data.id === 'selectAll') {
                $('#Dictators').val(event.params.data.Ids);
                $('#Dictators').trigger('change');
            };
        };

        $('#Dictators').on('select2:select', handleSelectionDictators);
        function FillProvidersDDL(selectedIds) {
             $('.Loader').show();
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: '/Managers/GetProviders',
                    data: JSON.stringify({ 'selectedIds': selectedIds }),
                    async: true,
                    success: function (data) {
                        $('#Dictators').html('').select2({
                            data: [{ id: '', text: '' }]
                        });
                        $("#Dictators").select2({
                            data: data,
                            placeholder: 'Select Provider(s)',
                            sorter: addSelectAllDictators,
                            allowClear: true,
                            theme: "classic",
                        });
                        $('.Loader').hide();
                        
                    }, error: function () {
                        $('.Loader').hide();
                    }
                });
        }

        function insert() { 
            $('.Loader').show();
            var Username = $('#Username').val();
            var isActive = $('#isActive').val();
            var confirmPassword = $('#confirmPassword').val();
        
            var data = {                
                'Username': Username,
                'isActive': isActive,
                'Password': confirmPassword,
                'ClinicIds': $('#Clinics').val(),
                'DictatorIds': $('#Dictators').val(),                
            };

            var json = JSON.stringify({ 'manager': data });
            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: '/Managers/Create',
                data: json,                
                success: function (response) {
                    $('.Loader').hide();
                    if (response.result != undefined) {
                        swal("Error!", response.result, "error");            
                    }
                    else {                    
                        window.location.href = '/Managers?message=Added';                        
                    }
                    
                }, error: function (xhr ,error) {
                    $('.Loader').hide();
                }
            });           
        }

    </script>
}