@model ExcelTranscript.Models.RegisterViewModel

@{
    ViewBag.Title = "Create";
}

<section class="content">
    <!-- *========== Main Heading ========== -->
    @*<div class="pt-3 pb-2">
            <div class="container-fluid">
                <h2 class="main-heading">Add Clinic</h2>
            </div>
        </div>*@

    <!-- *========== Breadcrumbs ========== -->
    <div>
        <div class="container-fluid">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-white px-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Typist")">Home</a></li>
                    <li class="breadcrumb-item active">Add Typist</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- *========== Form ========== -->
    <div class="py-3">
        <div class="container">
            <div class="row">
                <div class="col-md-10 m-auto">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()                        
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="form-title pb-2"><i class="fa fa-user-o" aria-hidden="true"></i> Typist Account Details</h4>
                            </div>
                            <div class="col-md-12">
                                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-6 pt-2 pb-1">
                                <div class="form-group">
                                    <label for="name">Typist UserName</label>
                                    @Html.EditorFor(model => model.UserName, new { htmlAttributes = new { @class = "form-control", @required = "required", placeholder = "Enter Username" } })
                                    @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-6">
                            </div>
                            <div class="col-md-6 py-1">
                                <div class="form-group">
                                    <label for="name">Password</label>
                                    @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg input-lg", placeholder = "Enter Password" })
                                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })

                                </div>
                            </div>
                            <div class="col-md-6 d-none">
                                @Html.DropDownList("UserRoles", new SelectList(new List<string> { "asdff" }), new { @class = "form-control form-control-lg input-lg" })
                            </div>
                            <div class="col-md-6 py-1">
                                <div class="form-group">
                                    <label for="name">Confirm Password</label>
                                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control form-control-lg input-lg", placeholder = "Confirm Password" })
                                    @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "text-danger" })

                                </div>
                            </div>
                        </div>
                        <div class="divider"></div>
                        <div class="row">
                            <div class="col-md-12 pt-2">
                                <input type="submit" value="Create Now" class="form-btn mr-2" />
                                <button type="button" class="form-btn mr-2" onclick="location.href='@Url.Action("Index", "Typist")'">
                                    <i class="fa fa-times" aria-hidden="true"></i>
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
          $(document).ready(function () {

                var message = '@ViewBag.message';
                if (message === 'Added')
                {
                    swal('Typist added successfully.', 'Excel Transcript', 'success');
                    window.history.pushState({}, document.title, window.location.pathname);
                }
                else if (message === 'Failed')
                {
                    swal('Failed to add the Typist.', 'Excel Transcript', 'error');
                    window.history.pushState({}, document.title, window.location.pathname);
                }

          });
    </script>
}
